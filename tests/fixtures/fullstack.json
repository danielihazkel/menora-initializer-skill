{
  "groupId": "com.demo",
  "artifactId": "app",
  "packageName": "com.demo.app",
  "type": "maven-project",
  "language": "java",
  "packaging": "jar",
  "bootVersion": "3.2.1",
  "javaVersion": "21",
  "dependencies": ["web", "data-jpa", "h2"],
  "backendTemplateSet": "spring-jpa-crud",
  "frontendTemplateSet": "react-tailwind-crud",
  "entities": [
    {
      "name": "Product",
      "tableName": "products",
      "fields": [
        { "name": "id", "type": "LONG", "primaryKey": true, "generated": true },
        { "name": "name", "type": "STRING", "required": true, "length": 255 }
      ]
    }
  ]
}
